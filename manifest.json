{
  "manifest_version": 3,
  "name": "Motion Extraction",
  "description": "Show only the motion in any web video, using Posy's invert-and-delay technique.",
  "version": "1.1",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Motion Extraction"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["motionEffect.js", "contentScript.js"]
    }
  ]
}
